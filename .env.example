# URL publique du proxy API MercatoTalk.
# En local web: http://localhost:8081/api
# En Expo Go sur mobile physique: http://VOTRE_IP_LAN:8081/api
# En production: https://votre-domaine-eas.expo.app/api
EXPO_PUBLIC_ITALPRO_API_URL=

# Compatibilite ancienne variable, ne pas utiliser sur un nouveau setup.
EXPO_PUBLIC_ITALPRO_AI_URL=

# Supabase public client. Ces valeurs peuvent etre exposees dans Expo si vos RLS sont actives.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Groq: secrets serveur uniquement. Ne jamais prefixer la cle Groq avec EXPO_PUBLIC_.
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo

# Kokoro TTS test rapide: Hugging Face Space public, aucune cle requise.
EXPO_PUBLIC_KOKORO_PROVIDER=hf-space
EXPO_PUBLIC_HF_KOKORO_SPACE_URL=https://hexgrad-kokoro-tts.hf.space/api/predict
EXPO_PUBLIC_KOKORO_TTS_VOICE=if_sara
EXPO_PUBLIC_HF_KOKORO_VOICE=if_sara
EXPO_PUBLIC_KOKORO_TTS_SPEED=1.0

# Kokoro TTS stable optionnel: HF Inference API avec token.
# Pour test client seulement. En production, preferer HF_TOKEN cote serveur.
EXPO_PUBLIC_HF_TOKEN=
EXPO_PUBLIC_HF_KOKORO_MODEL_URL=https://api-inference.huggingface.co/models/hexgrad/Kokoro-82M

# Kokoro cote serveur: hf-space par defaut, hf-inference avec HF_TOKEN, self-hosted avec KOKORO_TTS_BASE_URL.
KOKORO_TTS_PROVIDER=hf-space
HF_KOKORO_SPACE_URL=https://hexgrad-kokoro-tts.hf.space/api/predict
HF_TOKEN=
HF_KOKORO_MODEL_URL=https://api-inference.huggingface.co/models/hexgrad/Kokoro-82M
KOKORO_TTS_BASE_URL=
KOKORO_TTS_URL=
KOKORO_TTS_MODEL=kokoro
KOKORO_TTS_VOICE=if_sara
KOKORO_TTS_SPEED=1.0
KOKORO_TTS_RESPONSE_FORMAT=wav

# Supabase serveur / migrations / webhooks seulement.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
